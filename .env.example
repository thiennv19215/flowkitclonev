# Cloudflare Tunnel token for docker-compose cloudflared service.
# Create in Cloudflare Zero Trust → Networks → Tunnels → Create tunnel → Docker.
# Copy the token only into local .env (never commit .env).
CLOUDFLARE_TUNNEL_TOKEN=YOUR_CLOUDFLARE_TUNNEL_TOKEN

# Public hostname you configure in Cloudflare for the FlowKit API.
# Example route in Cloudflare dashboard:
#   https://YOUR_FLOWKIT_API_DOMAIN -> http://flowkit:8100
FLOWKIT_PUBLIC_API_URL=https://YOUR_FLOWKIT_API_DOMAIN
